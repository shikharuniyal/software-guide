# =====================================================================
#  CONFIGURATION TEMPLATE
#  ---------------------------------------------------------------------
#  Copy this file to ".env"  ( cp .env.example .env )  and edit the
#  values below. Docker Compose loads ".env" automatically.
#  Leaving a line unset simply falls back to the default shown here.
# =====================================================================

# --- Models -----------------------------------------------------------
# The vision + language model served by Ollama.
# Must already exist inside ./models/ollama (vendored, offline).
# For a low-memory machine you can switch to a smaller model, e.g. qwen2.5vl:3b,
# but that model's weights must be present in ./models/ollama first.
OLLAMA_MODEL=qwen2.5vl:7b

# The embedding model used for search. Must exist in ./models/ollama.
EMBED_MODEL=nomic-embed-text

# --- Host ports (what you open from a browser / curl on the server) ---
# Change these only if the defaults clash with something already running.
WEB_PORT=8080        # the web question page
API_PORT=8000        # the API (query / health / reload / guide)
CHROMA_PORT=8001     # the vector database (rarely accessed directly)
OLLAMA_PORT=11434    # the model server (rarely accessed directly)

# --- Phase 2 desktop client (client.py) -------------------------------
# The desktop guide runs on a Windows machine, NOT in Docker.
# Set this to the address of the server running this stack.
# On the same machine, keep localhost. On a real server, use its IP, e.g.
#   SERVER_URL=http://10.0.0.5:8000/guide
SERVER_URL=http://localhost:8000/guide
